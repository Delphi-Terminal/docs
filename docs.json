{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "appearance": {
    "default": "dark"
  },
  "name": "Delphi Markets API",
  "colors": {
    "primary": "#1B3A5F",
    "light": "#5B8AC4",
    "dark": "#0F1F3C"
  },
  "styling": {
    "codeblocks": {
      "theme": "one-dark-pro"
    }
  },
  "favicon": "/favicon.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Data",
            "pages": [
              "data-extraction"
            ]
          },
          {
            "group": "Examples",
            "pages": [
              "klsi-examples",
              "polymarket-examples"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "openapi.json"
      },
      {
        "tab": "WebSockets",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "websocket-examples"
            ]
          },
          {
            "group": "Streams",
            "openapi": "openapi-websockets.json"
          }
        ]
      },
      {
        "tab": "Changelog",
        "groups": [
          {
            "group": "Changelog",
            "pages": [
              "changelog"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "API Status",
          "href": "https://api.delphiterminal.co/health",
          "icon": "signal"
        }
      ]
    }
  },
  "logo": {
    "light": "/DelphiBlue.png",
    "dark": "/DelphiWhite.png",
    "size": 200
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@delphiterminal.co"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://delphiterminal.co"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/delphiterminal",
      "github": "https://github.com/delphiterminal"
    }
  },
  "api": {
    "openapi": "openapi.json",
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "autogenerate": false
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  }
}
